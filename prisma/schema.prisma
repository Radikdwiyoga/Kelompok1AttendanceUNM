// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        BigInt   @id @default(autoincrement())
  email     String   @unique @db.VarChar(150)
  username  String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  name      String   @db.VarChar(150)
  role      String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Class {
  id        BigInt     @id @default(autoincrement())
  name      String     @db.VarChar(100)
  students  Student[]
  schedules Schedule[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("classes")
}

model Student {
  id             BigInt       @id @default(autoincrement())
  name           String       @db.VarChar(150)
  nim            String       @unique @db.VarChar(50)
  password       String?      @db.VarChar(255)
  classId        BigInt       @map("class_id")
  faceDescriptor String?      @db.LongText @map("face_descriptor")
  class          Class        @relation(fields: [classId], references: [id])
  attendances    Attendance[]
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("students")
}

enum AttendanceStatus {
  hadir
  terlambat
  tidak_hadir
}

enum AttendanceType {
  IN
  OUT
}

model Attendance {
  id              BigInt           @id @default(autoincrement())
  studentId       BigInt           @map("student_id")
  date            DateTime         @db.Date
  time            DateTime         @db.Time(0)
  status          AttendanceStatus
  type            AttendanceType   @default(IN)
  confidenceScore Decimal?         @db.Decimal(5, 2) @map("confidence_score")
  latitude        Decimal?         @db.Decimal(10, 8)
  longitude       Decimal?         @db.Decimal(11, 8)
  locationStatus  String?          @db.VarChar(50) @map("location_status")
  student         Student          @relation(fields: [studentId], references: [id])
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("attendances")
}

model Schedule {
  id          BigInt   @id @default(autoincrement())
  subjectName String   @map("subject_name") @db.VarChar(150)
  classId     BigInt   @map("class_id")
  dayOfWeek   Int      @db.TinyInt // 1=Senin, 2=Selasa, etc.
  startTime   String   @map("start_time") @db.VarChar(10) // "08:00"
  endTime     String   @map("end_time") @db.VarChar(10) // "10:00"
  class       Class    @relation(fields: [classId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("schedules")
}

model Setting {
  id        BigInt   @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

